{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/embed.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=300" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/webhooks/airtable/refresh",
      "schedule": "0 6 * * *"
    }
  ]
}
